# ====== FitConnect server environment ======
# Copy this file to ".env" (same folder) and fill in your own values.
# The real .env is git-ignored so your secrets are never uploaded (requirement #7).

# Your MongoDB Atlas connection string.
# Get it from: Atlas -> Cluster -> Connect -> Drivers -> copy the string.
# Replace <username>, <password> and add the database name "fitconnect" before the "?".
# Example:
# MONGO_URI=mongodb+srv://myuser:mypass@cluster0.abcde.mongodb.net/fitconnect?retryWrites=true&w=majority
MONGO_URI=

# Any long random secret string used to sign login tokens.
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port the server listens on.
PORT=5000

# Where the React client runs (used for CORS). Vite default is 5173.
CLIENT_URL=http://localhost:5173
